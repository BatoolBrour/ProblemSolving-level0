#include <iostream>
using namespace std;
long long power(long long x,long long y){
    long long num=x;
    if(y==0) return 1;
    else if (y==1)
    return num;
    else {for(int i=2;i<=y;i++){
        num*=x;
    }return num;}
}
long long equation (long long x,int n){
    long long eq=0;
    for(int i=0;i<=n;i+=2){
        eq+=power(x,i);
    } return eq-1;
}
